generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// enum Categories {

// }

enum ScoutRanks {
  mlodzik_ochotniczka
  wywiadowca_tropicielka
  odkrywca_pionierka
  cwik_samarytanka
  ho
  hr
}

enum Levels {
  niebieski @map("1")
  zielony   @map("2")
  czerwony  @map("3")
  czarny    @map("4")
}

model Badge {
  id    String       @id @default(cuid())
  name  String
  idea  String
  level Levels
  rank  ScoutRanks[]
  tasks Task[]
}

model Task {
  id          String @id @default(cuid())
  description String
  badgeId     String
  badge       Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)
}
